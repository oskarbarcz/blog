---
import "../styles/global.css";
import "../styles/article.css";
import { ClientRouter } from "astro:transitions";
import { ThemeModeScript } from "flowbite-react";
import { ThemeInit } from "../../.flowbite-react/init";
import Navigation from "../components/shared/Navigation.tsx";
import Footer from "../components/shared/Footer.tsx";
import Analytics from "../components/shared/Analytics.astro";
import SmoothScroll from "../components/shared/SmoothScroll.astro";
import { DEFAULT_SITE_TITLE, SITE_TITLE_SUFFIX } from "../constants";
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <script is:inline>
      (() => {
        if (window.location.hash.length > 1) {
          window.__pendingHash = window.location.hash;
          try {
            history.scrollRestoration = "manual";
          } catch {}
          history.replaceState(
            null,
            "",
            window.location.pathname + window.location.search,
          );
        }
      })();
    </script>
    <meta name="generator" content={Astro.generator} />
    <meta name="format-detection" content="telephone=no" />
    <title>
      {
        (Astro.slots.has("title")
          ? await Astro.slots.render("title")
          : DEFAULT_SITE_TITLE) + SITE_TITLE_SUFFIX
      }
    </title>

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#40bf7e" />
    <meta name="msapplication-TileColor" content="#f8f9fa" />
    <meta name="theme-color" content="#40bf7e" />

    <slot name="head" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&family=Roboto+Slab:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <ThemeModeScript />
    <script is:inline>
      (() => {
        const applyTheme = () => {
          const mode = localStorage.getItem("flowbite-theme-mode") || "auto";
          const isDark =
            mode === "dark" ||
            (mode === "auto" &&
              window.matchMedia("(prefers-color-scheme: dark)").matches);
          document.documentElement.classList.toggle("dark", isDark);
        };
        document.addEventListener("astro:after-swap", applyTheme);
      })();
    </script>
    <Analytics />
    <ClientRouter />
  </head>
  <body class="flex min-h-dvh flex-col">
    <ThemeInit />
    <SmoothScroll />
    <Navigation client:load pathname={Astro.url.pathname} />
    <div
      id="page-content"
      class="flex-1 bg-linear-to-br from-gray-50 via-white to-gray-50 dark:from-[#020409] dark:via-[#05070d] dark:to-[#020409]"
    >
      <slot />
    </div>
    <Footer />
  </body>
</html>
