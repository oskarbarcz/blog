---
import { getCollection } from "astro:content";
import ArticlesList from "../components/articles/ArticlesList.tsx";
import Meta from "../components/shared/Meta.astro";
import Layout from "../layouts/Layout.astro";
import { CASE_STUDIES_PAGE_DESCRIPTION } from "../constants";

const allCaseStudies = await getCollection("caseStudies");

const caseStudies = allCaseStudies
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((article) => ({
    slug: article.id,
    title: article.data.title,
    excerpt: article.data.excerpt,
    date: article.data.date.toISOString(),
    readTime: article.data.readTime,
    tags: article.data.tags,
    coverUrl: article.data.coverUrl,
    language: article.data.language,
  }));
---

<Layout>
  <Fragment slot="title">Case studies</Fragment>
  <Meta
    slot="head"
    title="Case studies"
    description={CASE_STUDIES_PAGE_DESCRIPTION}
    keywords={[
      "case study",
      "studium przypadku",
      "architektura oprogramowania",
      "programowanie",
    ]}
  />
  <ArticlesList
    articles={caseStudies}
    title="Case studies"
    subtitle={CASE_STUDIES_PAGE_DESCRIPTION}
    basePath="/case-studies"
    client:load
  />
</Layout>
