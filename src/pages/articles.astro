---
import { getCollection } from "astro:content";
import ArticlesList from "../components/articles/ArticlesList.tsx";
import Meta from "../components/shared/Meta.astro";
import Layout from "../layouts/Layout.astro";
import { ARTICLES_PAGE_DESCRIPTION } from "../constants";

const allArticles = await getCollection("articles");

const articles = allArticles
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .map((article) => ({
    slug: article.id,
    title: article.data.title,
    excerpt: article.data.excerpt,
    date: article.data.date.toISOString(),
    readTime: article.data.readTime,
    tags: article.data.tags,
    coverUrl: article.data.coverUrl,
    language: article.data.language,
  }));
---

<Layout>
  <Fragment slot="title">Wszystkie publikacje</Fragment>
  <Meta
    slot="head"
    title="Wszystkie publikacje"
    description={ARTICLES_PAGE_DESCRIPTION}
    keywords={[
      "blog",
      "artykuły IT",
      "architektura oprogramowania",
      "programowanie",
    ]}
  />
  <ArticlesList articles={articles} client:load />
</Layout>
